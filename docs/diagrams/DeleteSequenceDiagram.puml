@startuml
!include style.puml
skinparam ArrowFontStyle plain
skinparam defaultFontSize 20
skinparam sequenceMessageFontSize 20
skinparam sequenceParticipantFontSize 20
skinparam sequenceGroupFontSize 20
skinparam dpi 180

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":DeleteAthleteCommandParser" as DeleteAthleteCommandParser LOGIC_COLOR
participant "d:DeleteAthleteCommand" as DeleteAthleteCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("del 1")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("del 1")
activate AddressBookParser

create DeleteAthleteCommandParser
AddressBookParser -> DeleteAthleteCommandParser
activate DeleteAthleteCommandParser

DeleteAthleteCommandParser --> AddressBookParser
deactivate DeleteAthleteCommandParser

AddressBookParser -> DeleteAthleteCommandParser : parse("1")
activate DeleteAthleteCommandParser

create DeleteAthleteCommand
DeleteAthleteCommandParser -> DeleteAthleteCommand
activate DeleteAthleteCommand

DeleteAthleteCommand --> DeleteAthleteCommandParser :
deactivate DeleteAthleteCommand

DeleteAthleteCommandParser --> AddressBookParser : d
deactivate DeleteAthleteCommandParser
'Hidden arrow to position the destroy marker below the end of the activation bar.
DeleteAthleteCommandParser -[hidden]-> AddressBookParser
destroy DeleteAthleteCommandParser

AddressBookParser --> LogicManager : d
deactivate AddressBookParser

LogicManager -> DeleteAthleteCommand : execute(m)
activate DeleteAthleteCommand

DeleteAthleteCommand -> Model : getFilteredPersonList()
activate Model
Model --> DeleteAthleteCommand : lastShownList
deactivate Model

DeleteAthleteCommand -> DeleteAthleteCommand : personToDelete = lastShownList.get(targetIndex)

DeleteAthleteCommand -> Model : deletePerson(personToDelete)
activate Model
Model --> DeleteAthleteCommand
deactivate Model

create CommandResult
DeleteAthleteCommand -> CommandResult
activate CommandResult

CommandResult --> DeleteAthleteCommand
deactivate CommandResult

DeleteAthleteCommand --> LogicManager : r
deactivate DeleteAthleteCommand

[<--LogicManager
deactivate LogicManager
@enduml
